{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://delano.local/schemas/artifacts/roadmap_item.schema.json",
  "title": "Delano roadmap item frontmatter",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "status",
    "horizon",
    "created",
    "updated"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^RM-[0-9]{3}$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "planned",
        "active",
        "done",
        "deferred"
      ]
    },
    "horizon": {
      "enum": [
        "now",
        "next",
        "later"
      ]
    },
    "created": {
      "type": "string",
      "format": "date-time"
    },
    "updated": {
      "type": "string",
      "format": "date-time"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "active"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "properties": {
          "horizon": {
            "const": "now"
          }
        }
      }
    }
  ]
}
