{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://delano.local/schemas/artifacts/review.schema.json",
  "title": "Delano published review frontmatter",
  "description": "Canonical frontmatter for a tracked review Markdown artifact under .project/reviews/. Drafts and machine-local launch or migration receipts are outside this schema.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "review_id",
    "name",
    "status",
    "created_at",
    "updated_at",
    "source",
    "findings"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "review_id": {
      "type": "string",
      "pattern": "^review-[0-9]{8}T[0-9]{6}Z-[a-z0-9][a-z0-9-]{0,62}$"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "status": {
      "enum": [
        "open",
        "resolved",
        "archived"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "author_display_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "pattern": "^[^@\\r\\n]+$",
      "description": "Optional human-chosen display label only. Email addresses, account ids, host names, and local user names are not supported provenance."
    },
    "source": {
      "$ref": "#/$defs/source"
    },
    "findings": {
      "type": "array",
      "minItems": 1,
      "maxItems": 500,
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "migration": {
      "$ref": "#/$defs/migration"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "open"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "properties": {
          "findings": {
            "contains": {
              "properties": {
                "status": {
                  "const": "open"
                }
              },
              "required": [
                "status"
              ]
            },
            "minContains": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "resolved"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "properties": {
          "findings": {
            "not": {
              "contains": {
                "properties": {
                  "status": {
                    "const": "open"
                  }
                },
                "required": [
                  "status"
                ]
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "repositoryProjectPath": {
      "type": "string",
      "minLength": 12,
      "maxLength": 1024,
      "pattern": "^\\.project/(?!/)(?!\\.\\.?/)(?!.*//)(?!.*/\\.\\.?/)(?!.*\\\\)[^\\u0000]+\\.md$",
      "description": "Repository-relative POSIX path below .project/. Absolute paths, traversal, backslashes, and worktree-local paths are forbidden."
    },
    "gitObjectId": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^(?:[0-9a-f]{40}|[0-9a-f]{64})$"
    },
    "contentHash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "branch_at_creation",
        "content_state",
        "commit",
        "blob",
        "hash_algorithm",
        "content_hash"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/repositoryProjectPath"
        },
        "branch_at_creation": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1,
          "maxLength": 255,
          "pattern": "^(?![A-Za-z]:)(?!/)(?!.*\\\\).+$",
          "description": "Branch provenance only. Null represents a detached worktree."
        },
        "content_state": {
          "enum": [
            "committed",
            "uncommitted"
          ]
        },
        "commit": {
          "$ref": "#/$defs/gitObjectId"
        },
        "blob": {
          "$ref": "#/$defs/gitObjectId"
        },
        "hash_algorithm": {
          "const": "sha256-utf8-lf-v1"
        },
        "content_hash": {
          "$ref": "#/$defs/contentHash"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "content_state": {
                "const": "uncommitted"
              }
            },
            "required": [
              "content_state"
            ]
          },
          "then": {
            "properties": {
              "commit": {
                "type": "null"
              },
              "blob": {
                "type": "null"
              }
            }
          },
          "else": {
            "properties": {
              "commit": {
                "type": "string",
                "pattern": "^(?:[0-9a-f]{40}|[0-9a-f]{64})$"
              }
            }
          }
        }
      ]
    },
    "anchor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state",
        "line_start",
        "line_end",
        "start_offset",
        "end_offset"
      ],
      "properties": {
        "state": {
          "enum": [
            "exact",
            "reanchored",
            "unanchored"
          ],
          "description": "Persisted publication state. Runtime source-hash mismatch always makes the review stale even when a quote can be reanchored."
        },
        "line_start": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "line_end": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "start_offset": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "end_offset": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "block_id": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 100
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "state": {
                "const": "unanchored"
              }
            },
            "required": [
              "state"
            ]
          },
          "then": {
            "properties": {
              "line_start": {
                "type": "null"
              },
              "line_end": {
                "type": "null"
              },
              "start_offset": {
                "type": "null"
              },
              "end_offset": {
                "type": "null"
              }
            }
          },
          "else": {
            "properties": {
              "line_start": {
                "type": "integer",
                "minimum": 1
              },
              "line_end": {
                "type": "integer",
                "minimum": 1
              },
              "start_offset": {
                "type": "integer",
                "minimum": 0
              },
              "end_offset": {
                "type": "integer",
                "minimum": 0
              }
            }
          }
        }
      ]
    },
    "message": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "created_at",
        "body"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^M-[0-9]{3,}$"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "author_display_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100,
          "pattern": "^[^@\\r\\n]+$"
        },
        "body": {
          "type": "string",
          "minLength": 1,
          "maxLength": 20000
        }
      }
    },
    "resolution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "resolved_at",
        "summary"
      ],
      "properties": {
        "resolved_at": {
          "type": "string",
          "format": "date-time"
        },
        "resolved_by_display_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100,
          "pattern": "^[^@\\r\\n]+$"
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 20000
        }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "severity",
        "status",
        "quote",
        "anchor",
        "labels",
        "thread",
        "resolution"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^F-[0-9]{3,}$"
        },
        "kind": {
          "enum": [
            "comment",
            "issue",
            "question",
            "suggestion"
          ]
        },
        "severity": {
          "enum": [
            "note",
            "minor",
            "major",
            "blocking"
          ]
        },
        "status": {
          "enum": [
            "open",
            "resolved",
            "wont-fix"
          ]
        },
        "quote": {
          "type": "string",
          "minLength": 0,
          "maxLength": 20000
        },
        "anchor": {
          "$ref": "#/$defs/anchor"
        },
        "labels": {
          "type": "array",
          "maxItems": 20,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 50
          },
          "uniqueItems": true
        },
        "thread": {
          "type": "array",
          "minItems": 1,
          "maxItems": 200,
          "items": {
            "$ref": "#/$defs/message"
          }
        },
        "resolution": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/resolution"
            }
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "const": "open"
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "properties": {
              "resolution": {
                "type": "null"
              }
            }
          },
          "else": {
            "properties": {
              "resolution": {
                "$ref": "#/$defs/resolution"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "anchor": {
                "properties": {
                  "state": {
                    "enum": [
                      "exact",
                      "reanchored"
                    ]
                  }
                },
                "required": [
                  "state"
                ]
              }
            },
            "required": [
              "anchor"
            ]
          },
          "then": {
            "properties": {
              "quote": {
                "minLength": 1
              }
            }
          }
        }
      ]
    },
    "migration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_kind",
        "legacy_ids"
      ],
      "properties": {
        "source_kind": {
          "enum": [
            "legacy-annotations",
            "legacy-handover"
          ]
        },
        "legacy_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          },
          "uniqueItems": true
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500
          }
        }
      }
    }
  }
}
